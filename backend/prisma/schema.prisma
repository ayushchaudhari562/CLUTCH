generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  content    String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes      Like[]
  comments   Comment[]
}

model User {
  id            Int      @id @default(autoincrement())
  clerkId       String?  @unique
  username      String   @unique
  email         String   @unique
  passwordHash  String
  fullName      String?
  collegeName   String? 
  collegeId     Int?      
  bio           String?
  profileImage  String?
  createdAt     DateTime @default(now())
  posts         Post[]
  likes         Like[]
  comments      Comment[]
}


model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  parent_main String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Colleges{
   id       Int     @id
   name     String  @unique
}
